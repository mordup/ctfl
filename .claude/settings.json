{
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(**/.claude/.credentials.json)",
      "Read(**/.cache/ctfl/*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-sensitive-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in *.py) ruff check --fix \"$f\" ;; esac; } 2>/dev/null || true",
            "statusMessage": "Running ruff..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; case \"$f\" in */ctfl/*.py|*/tests/*.py) python -m pytest tests/ -q --tb=short ;; esac; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ]
  }
}
